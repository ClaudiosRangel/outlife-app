# Supabase (obrigatório)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-anon-key
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# Supabase Project ID (opcional, para CLI)
SUPABASE_PROJECT_ID=your-project-id
VITE_SUPABASE_PROJECT_ID=your-project-id

# Supabase Service Role Key (obrigatório, usada por src/integrations/supabase/client.server.ts)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Places API (opcional, server-side apenas — sem prefixo VITE_)
GOOGLE_PLACES_API_KEY=your-google-places-api-key

# Sentry — Error Monitoring Service (opcional, client + server)
SENTRY_DSN=https://your-key@oXXXXXX.ingest.us.sentry.io/XXXXXXX
VITE_SENTRY_DSN=https://your-key@oXXXXXX.ingest.us.sentry.io/XXXXXXX
